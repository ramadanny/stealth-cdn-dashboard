# Admin Authentication
ADMIN_PASSWORD=example123    # Strong password to protect your dashboard access

# GitHub Storage Configuration
GITHUB_TOKEN=ghp_xxx       # Classic Token with 'repo' scope or Fine-grained with 'Contents' write access
GITHUB_OWNER=ramadanny   # Your GitHub account username
GITHUB_REPO=cdn            # The name of your public storage repository
GITHUB_BRANCH=main        # Target branch for file uploads

# Session Security
JWT_SECRET=example123        # Private key used to sign and verify your login sessions